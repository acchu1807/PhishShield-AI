# GEMINI_API_KEY: Required for Gemini AI analysis.
# Get your key at https://aistudio.google.com/app/apikey 
# (Settings -> Secrets in AI Studio)
GEMINI_API_KEY=""

# GOOGLE_SAFE_BROWSING_API_KEY: Optional. Enables threat checks.
# Note: Ensure the Safe Browsing API is enabled in your Google Cloud Project.
GOOGLE_SAFE_BROWSING_API_KEY=""

# IPQUALITYSCORE_API_KEY: Optional. Deep domain reputation checks.
IPQUALITYSCORE_API_KEY=""

# APP_URL: Injected automatically by the platform at runtime.
APP_URL=""
